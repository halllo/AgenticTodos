{
  "name": "agentic-todos",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "build:sandbox": "esbuild src/sandbox.ts --bundle --platform=browser --outfile=../backend/wwwroot/sandbox.js",
    "start": "npm run build:sandbox && ng serve",
    "dev": "npm run build:sandbox && ng serve",
    "build": "npm run build:sandbox && ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.13.0",
  "dependencies": {
    "@ag-ui/client": "^0.0.53",
    "@ag-ui/core": "^0.0.53",
    "@angular/common": "^21.2.11",
    "@angular/compiler": "^21.2.11",
    "@angular/core": "^21.2.11",
    "@angular/forms": "^21.2.11",
    "@angular/platform-browser": "^21.2.11",
    "@angular/router": "^21.2.11",
    "@mcp-b/global": "^2.2.0",
    "@mcp-b/transports": "^2.2.0",
    "@modelcontextprotocol/ext-apps": "^1.7.1",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.9",
    "@angular/cli": "^21.2.9",
    "@angular/compiler-cli": "^21.2.11",
    "esbuild": "latest",
    "jsdom": "^29.1.1",
    "typescript": "~5.9.3",
    "vitest": "^4.1.5"
  }
}
